# The base URL for the Laravel API.
#
# Use a relative path (/api) so all requests flow through the Vite dev server
# proxy (vite.config.ts server.proxy). This keeps every request same-origin
# from the browser's perspective — no CORS preflight, no X-XSRF-TOKEN CORS
# header negotiation, and Sanctum SPA cookies work without domain quirks.
#
# DO NOT set this to http://localhost:8010/api in development. That creates
# cross-origin requests (localhost:5173 -> localhost:8010) which require the
# browser to send CORS preflights that must explicitly allow X-XSRF-TOKEN.
VITE_API_BASE_URL=/api

# Runtime mode determines the frontend data source and service worker behavior.
#
#   vertical  = Real backend runtime (Laravel + PostgreSQL via Vite proxy).
#               This is the DEFAULT. All business verticals (CondoFlow, etc.)
#               use this mode. MSW browser worker is NEVER started.
#
#   cookbook   = MSW/reference runtime (Mock Service Worker intercepts /api/*).
#               Used ONLY for the Reference Cookbook module.
#               Must be set EXPLICITLY — cookbook is opt-in.
#
# If unset, the platform defaults to "vertical" to ensure requests always
# reach the real backend. Set to "cookbook" only for UI pattern development.
VITE_RUNTIME_MODE=vertical
